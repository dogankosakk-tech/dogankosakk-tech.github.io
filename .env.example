# Port (optional, default 3333)
# PORT=3333

# Telegram: Müşteri chatbot'tan yazınca size bu numaraya/sohbet ID'ye mesaj gider; siz yanıtlayınca müşteri chatbot'ta görür.
# Bot oluşturmak: Telegram'da @BotFather'a /newbot deyin, token'ı alın.
# Chat ID almak: @userinfobot'a /start deyin veya botunuza bir mesaj atıp şu adrese gidin:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Opsiyonel: OpenAI API key. Tanımlıysa müşteri mesajına otomatik kısa bir AI yanıtı da gider (yanıt sizden önce chatbot'ta görünür).
# OPENAI_API_KEY=
